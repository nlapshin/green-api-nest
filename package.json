{
  "name": "green-api-integration-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Production-style GREEN-API integration gateway (NestJS + Fastify)",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
