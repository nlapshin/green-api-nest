<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GREEN-API Console</title>
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <header class="app-header">
      <div class="brand">
        <span class="brand__title">GREEN-API</span>
        <span class="brand__subtitle">integration gateway · local UI</span>
      </div>
    </header>

    <main class="layout" data-api-base="{{apiBase}}">
      <section class="panel panel--actions" aria-label="Действия">
        <h2 class="panel__heading">Действия</h2>

        <fieldset class="field-group">
          <legend>Учётные данные инстанса</legend>
          <label class="field">
            <span class="field__label">idInstance</span>
            <input id="idInstance" name="idInstance" type="text" inputmode="numeric" autocomplete="off" />
          </label>
          <label class="field">
            <span class="field__label">apiTokenInstance</span>
            <input id="apiTokenInstance" name="apiTokenInstance" type="password" autocomplete="off" />
          </label>
        </fieldset>

        <div class="actions-row">
          <button type="button" class="btn" data-action="get-settings">getSettings</button>
          <button type="button" class="btn" data-action="get-state-instance">getStateInstance</button>
        </div>

        <fieldset class="field-group">
          <legend>sendMessage</legend>
          <label class="field">
            <span class="field__label">chatId</span>
            <input id="chatIdMessage" type="text" placeholder="79001234567@c.us" autocomplete="off" />
          </label>
          <label class="field">
            <span class="field__label">message</span>
            <textarea id="messageBody" rows="4" autocomplete="off"></textarea>
          </label>
          <button type="button" class="btn btn--primary" data-action="send-message">sendMessage</button>
        </fieldset>

        <fieldset class="field-group">
          <legend>sendFileByUrl</legend>
          <label class="field">
            <span class="field__label">chatId</span>
            <input id="chatIdFile" type="text" placeholder="79001234567@c.us" autocomplete="off" />
          </label>
          <label class="field">
            <span class="field__label">fileUrl</span>
            <input id="fileUrl" type="url" placeholder="https://example.com/file.pdf" autocomplete="off" />
          </label>
          <label class="field">
            <span class="field__label">fileName (optional)</span>
            <input id="fileName" type="text" autocomplete="off" />
          </label>
          <label class="field">
            <span class="field__label">caption (optional)</span>
            <textarea id="caption" rows="2" autocomplete="off"></textarea>
          </label>
          <button type="button" class="btn btn--primary" data-action="send-file-by-url">sendFileByUrl</button>
        </fieldset>
      </section>

      <section class="panel panel--response" aria-label="Ответ">
        <div class="response-toolbar">
          <h2 class="panel__heading">Ответ</h2>
          <div class="response-meta">
            <span id="lastStatus" class="badge badge--muted">idle</span>
            <span id="lastDuration" class="muted"></span>
          </div>
          <div class="response-actions">
            <button type="button" class="btn btn--ghost" id="copyResponse">Копировать</button>
            <button type="button" class="btn btn--ghost" id="clearResponse">Очистить</button>
          </div>
        </div>
        <textarea
          id="responseBody"
          class="response-body"
          readonly
          rows="24"
          spellcheck="false"
          aria-readonly="true"
        ></textarea>
      </section>
    </main>

    <div id="toast" class="toast" role="status" aria-live="polite" hidden></div>

    <script src="/static/app.js" type="module"></script>
  </body>
</html>
